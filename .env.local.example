# ============================================================
# SBK Ops Chat — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Database -----------------------------------------------
# Primary connection string (pooled, used by Prisma at runtime)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Direct / unpooled connection for Prisma Migrate and schema introspection.
# Required by Vercel Postgres / Neon; may be the same as DATABASE_URL for
# self-hosted PostgreSQL without a connection pooler.
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/dbname

# --- AI APIs ------------------------------------------------
# Anthropic API key (Claude models — chat + document classification)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Voyage AI API key (voyage-3 embeddings for RAG)
VOYAGE_API_KEY=pa-...

# --- Authentication -----------------------------------------
# Shared password that all operators use to authenticate.
# Used as the HMAC message when generating sbk_auth_token.
ACCESS_PASSWORD=escolha-uma-senha-forte

# Admin panel password.
# Used as the HMAC message when generating sbk_admin_token.
ADMIN_PASSWORD=escolha-uma-senha-admin-forte

# HMAC signing secret for cookies.
# MUST be at least 32 characters — the app will refuse to start otherwise.
# Generate with: openssl rand -hex 32
AUTH_SECRET=gere-uma-string-aleatoria-de-pelo-menos-32-caracteres-aqui

# Single-use invite code for operator self-registration.
# Keep this secret; anyone with this code can create a (pending) account.
# Rotate if you suspect it has been leaked.
INVITE_CODE=codigo-de-convite-sbk
