# Database — Vercel Postgres (ou qualquer PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Senha de acesso para os operadores
ACCESS_PASSWORD=escolha-uma-senha-forte

# Senha de acesso ao painel de administração
ADMIN_PASSWORD=escolha-uma-senha-admin-forte

# Segredo para assinatura dos cookies (string aleatória, mínimo 32 caracteres)
AUTH_SECRET=gere-uma-string-aleatoria-de-pelo-menos-32-caracteres-aqui
